name: Deploy Static HTML to GitHub Pages

# ทำงานเมื่อมีการ Push โค้ดเข้า branch main (หรือเปลี่ยนเป็น master ถ้าคุณใช้ master)
on:
  push:
    branches: ["main"]
  # อนุญาตให้กดรัน Workflow นี้ได้แบบ Manual บนหน้าเว็บ GitHub
  workflow_dispatch:

# กำหนดสิทธิ์ที่จำเป็นสำหรับการ Deploy ลง GitHub Pages
permissions:
  contents: read
  pages: write
  id-token: write

# ป้องกันไม่ให้ Deploy ซ้อนทับกันหลายรอบพร้อมกัน
concurrency:
  group: "pages"
  cancel-in-progress: false

jobs:
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Pages
        uses: actions/configure-pages@v5

      - name: Upload artifact
        # ใช้ upload-pages-artifact แทน upload-artifact ธรรมดา
        uses: actions/upload-pages-artifact@v3
        with:
          # ระบุพาธโฟลเดอร์ที่มีไฟล์ index.html ของคุณ ('.' หมายถึงโฟลเดอร์นอกสุด)
          path: '.'

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4 # หรือใช้ v5 ตามที่คุณใช้อยู่ก็ได้
